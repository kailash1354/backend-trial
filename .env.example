# =========================================
# APPLICATION
# =========================================
NODE_ENV=development
PORT=4000
APP_NAME=Doctor House API
APP_URL=http://localhost:4000
CLIENT_URL=http://localhost:8080

# =========================================
# DATABASE
# =========================================
MONGODB_URI=mongodb://127.0.0.1:27017/doctor-house
MONGODB_DB_NAME=Doctor-House-Aditya

# =========================================
# AUTH / JWT
# =========================================
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# =========================================
# CORS / COOKIES
# =========================================
COOKIE_DOMAIN=localhost
CORS_ORIGIN=http://localhost:8080,http://localhost:5173

# =========================================
# UPLOADS / MEDIA
# =========================================
UPLOAD_PROVIDER=local
UPLOAD_DIR=uploads

# =========================================
# SECURITY / LIMITS
# =========================================
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
LOG_LEVEL=info

# =========================================
# PASSWORD / EMAIL
# =========================================
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=60
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com

# =========================================
# ADMIN SEED
# =========================================
ADMIN_SEED_EMAIL=kailashaghav1354@gmail.com
ADMIN_SEED_PASSWORD=cereza
ADMIN_SEED_NAME=JAKK Admin
ADMIN_SEED_ROLES=admin
